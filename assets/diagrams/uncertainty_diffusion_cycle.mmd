flowchart TD
    A[Anchor available] --> B[Belief state constrained]
    B --> C[Anchor loss]
    C --> D[Uncertainty diffusion]
    D --> E[Small informative action]
    E --> F[Re-anchor]
    F --> G[Updated belief state]
    G --> A

    D --> EQ1["P_{t+Delta t} = P_t + Q Delta t"]
    E --> EQ2["V(a) = I(a) + B(a) - C(a)"]

    C:::loss
    D:::diffusion
    E:::action
    F:::anchor

    classDef loss fill:#ffebee,stroke:#c62828,stroke-width:1px;
    classDef diffusion fill:#fff3e0,stroke:#ef6c00,stroke-width:1px;
    classDef action fill:#e3f2fd,stroke:#1565c0,stroke-width:1px;
    classDef anchor fill:#e8f5e9,stroke:#2e7d32,stroke-width:1px;
